{
	"name": "PlaceCal",
	"description": "The Community Calendar",
	"scripts": {
		"postdeploy": "bundle exec rails db:migrate"
	},
	"cron_note": "Cron jobs are managed by the whenever gem (config/schedule.rb) and run in a dedicated container. See INSTALL.md.",
	"cron": [
		{
			"command": "bundle exec rails events:scan_for_calendars_needing_import",
			"schedule": "0 * * * *"
		},
		{
			"command": "bundle exec rails counters:refresh_all",
			"schedule": "30 4 * * *"
		},
		{
			"command": "bundle exec rails db:clean_bad_addresses",
			"schedule": "30 5 * * *"
		},
		{
			"command": "bundle exec rails events:deduplicate",
			"schedule": "0 4 * * *"
		}
	]
}
