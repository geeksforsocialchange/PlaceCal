# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database and any backups
/db/*.sqlite3
/db/*.sqlite3-journal
/db/backups/*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore Byebug command history file.
.byebug_history

# System file junk
.DS_Store
.fontello

# User config
.env
.env.*
.kamal/*.pem
.kamal/secrets.staging
.kamal/secrets.production

# Files
/public/uploads/**
/public/assets/**

# Notes
notes.md

# Source images
/app/assets/images/presentation/_source

# Coverage
coverage

# ERD pdf as it's messing up diffs
erd.pdf

# Ignore the dump directory
dump/

# Ignore node stuff
/node_modules/**

/node_modules
/yarn-error.log
yarn-debug.log*
/app/assets/builds/*
!/app/assets/builds/.keep

doc/yard
doc/rdoc
.yardoc
./tags

# RBS type collection cache (regenerate with: bundle exec rbs collection install)
/.gem_rbs_collection

# Ignore IDE config files
.vscode
/config/master.key

# AI coding assistants (user-specific settings)
.claude/
.claude-swarm/
claude-swarm.log
spec/examples.txt
.mcp.json