<%= render(Components::Admin::Error.new(f.object)) %>

<%# Radio Tabs - daisyUI tabs-lift %>
<div class="tabs tabs-lift">
  <%= render Components::Admin::TabPanel.new(
    name: 'user_tabs',
    label: '👤 Personal Details',
    hash: 'personal',
    controller_name: 'form-tabs',
    checked: true
  ) do %>
    <%= render 'form_tab_personal', f: f %>
  <% end %>

  <%= render Components::Admin::TabPanel.new(
    name: 'user_tabs',
    label: '🔑 Permissions',
    hash: 'permissions',
    controller_name: 'form-tabs'
  ) do %>
    <%= render 'form_tab_roles', f: f %>
  <% end %>

  <% if policy(@user).permitted_attributes_for_update.include?(:role) || policy(@user).destroy? %>
    <%# Spacer to push Admin tab right %>
    <div class="tab flex-1 cursor-default"></div>

    <%= render Components::Admin::TabPanel.new(
      name: 'user_tabs',
      label: '⚙️ Settings',
      hash: 'settings',
      controller_name: 'form-tabs'
    ) do %>
      <%= render 'form_tab_settings', f: f %>
    <% end %>
  <% end %>
</div>
