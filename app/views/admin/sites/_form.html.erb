<%= simple_form_for [:admin, @site], html: { data: { controller: 'form-tabs live-validation', 'form-tabs-storage-key-value': 'siteTabAfterSave' } } do |f| %>
  <%= render(Views::Admin::Components::Error.new(@site)) %>

  <%= render Views::Admin::Components::TabForm.new(
    tabs: [
      { label: '📋 Basic Info', hash: 'basic', partial: 'form_tab_basic' },
      { label: '🖼️ Images', hash: 'images', partial: 'form_tab_images' },
      { label: '📍 Neighbourhoods', hash: 'neighbourhoods', partial: 'form_tab_neighbourhoods' },
      { label: '🏷️ Partnerships', hash: 'partnerships', partial: 'form_tab_partnerships' },
      { label: '👁️ Preview', hash: 'preview', partial: 'form_tab_preview', persisted_only: true },
      { label: '⚙️ Settings', hash: 'settings', partial: 'form_tab_settings', spacer_before: true }
    ],
    tab_name: 'site_tabs',
    storage_key: 'siteTabAfterSave',
    settings_hash: 'settings',
    preview_hash: 'preview',
    form: f,
    record: @site
  ) %>
<% end %>
