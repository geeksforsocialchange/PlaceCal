<% unless @calendar.new_record? %>
  <%= render('importer_overview', calendar: @calendar) %>
<% end %>

<%= simple_form_for [:admin, @calendar], html: { data: { controller: 'form-tabs live-validation', 'form-tabs-storage-key-value': 'calendarTabAfterSave' } } do |f| %>
  <div class="mt-6">
    <%= render Views::Admin::Components::TabForm.new(
      tabs: [
        { label: '📥 Source', hash: 'source', partial: 'form_tab_source' },
        { label: '📍 Location', hash: 'location', partial: 'form_tab_location' },
        { label: '📞 Contact', hash: 'contact', partial: 'form_tab_contact' },
        { label: '👁️ Preview', hash: 'preview', partial: 'form_tab_preview', persisted_only: true },
        { label: '⚙️ Settings', hash: 'settings', partial: 'form_tab_settings', persisted_only: true, spacer_before: true }
      ],
      tab_name: 'calendar_tabs',
      storage_key: 'calendarTabAfterSave',
      settings_hash: 'settings',
      preview_hash: 'preview',
      form: f,
      record: @calendar
    ) %>
  </div>
<% end %>
