# Kamal secrets — sourced before each deploy
# These pull from the deployer's environment or a secrets manager.
#
# See https://kamal-deploy.org/docs/configuration/environment-variables/

# GitHub Container Registry
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails
RAILS_ENV=$RAILS_ENV
SECRET_KEY_BASE=$SECRET_KEY_BASE
RAILS_MASTER_KEY=$RAILS_MASTER_KEY
SITE_DOMAIN=$SITE_DOMAIN

# Database (used by both the app and the postgres accessory)
POSTGRES_HOST=$POSTGRES_HOST
POSTGRES_PORT=$POSTGRES_PORT
POSTGRES_DB=$POSTGRES_DB
POSTGRES_USER=$POSTGRES_USER
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
PGPASSWORD=$POSTGRES_PASSWORD

# Email (MailerSend SMTP)
MAILERSEND_USERNAME=$MAILERSEND_USERNAME
MAILERSEND_PASSWORD=$MAILERSEND_PASSWORD

# Monitoring
APPSIGNAL_PUSH_API_KEY=$APPSIGNAL_PUSH_API_KEY

# Third-party APIs
EVENTBRITE_TOKEN=$EVENTBRITE_TOKEN

# SSL (Cloudflare Origin CA certificate for use behind Cloudflare proxy)
SSL_CERTIFICATE_PEM=$SSL_CERTIFICATE_PEM
SSL_PRIVATE_KEY_PEM=$SSL_PRIVATE_KEY_PEM
