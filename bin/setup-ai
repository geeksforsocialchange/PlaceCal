#!/usr/bin/env bash
set -euo pipefail

# Install PlaceCal's vendored Claude Code plugins (agents + a skill) into the
# local, gitignored .claude/ directory by symlinking them from their tracked
# source of truth in doc/ai/plugins/. Idempotent — safe to re-run.
#
# The plugins themselves are documented in doc/ai/plugins/README.md.

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT/doc/ai/plugins"

echo "Setting up AI coding assistant support..."

mkdir -p "$ROOT/.claude/agents" "$ROOT/.claude/skills"

link() { # link <target> <linkname>
  ln -sfn "$1" "$2"
  echo "  linked $(basename "$2") -> ${1#"$ROOT"/}"
}

# Agents (single markdown files)
link "$SRC/better-stimulus/agent.md"        "$ROOT/.claude/agents/better-stimulus.md"

# Skills (whole directory, scripts co-located)
link "$SRC/rails-hotwire-driver"            "$ROOT/.claude/skills/rails-hotwire-driver"

cat <<'EOF'

AI tooling installed successfully!

What you get (see doc/ai/plugins/README.md):
  - better-stimulus       agent  — StimulusJS best practices
  - rails-hotwire-driver  skill  — drive the running dev server to verify changes

Context for assistants stays in:
  - AGENTS.md / doc/ai/context.md  — project conventions
  - doc/ai/prompts/                — per-domain guidance

Edit the plugins in doc/ai/plugins/ (the symlinks point back there); re-run
this script if the links go stale.

To remove the local links later:
  rm -f .claude/agents/better-stimulus.md
  rm -f .claude/skills/rails-hotwire-driver
EOF
