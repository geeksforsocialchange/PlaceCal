{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"helpers:pinGitHubActionDigests",
		"schedule:nonOfficeHours"
	],
	"automerge": true,
	"automergeStrategy": "squash",
	"labels": ["dependencies"],
	"lockFileMaintenance": {
		"enabled": true
	},
	"rangeStrategy": "pin",
	"timezone": "Europe/London",
	"vulnerabilityAlerts": {
		"labels": ["security"]
	},
	"customManagers": [
		{
			"customType": "regex",
			"fileMatch": ["^Dockerfile$"],
			"matchStrings": [
				"ARG RUBY_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)\\n"
			],
			"depNameTemplate": "ruby",
			"datasourceTemplate": "ruby-version"
		}
	],
	"packageRules": [
		{
			"matchDatasources": ["docker"],
			"matchPackageNames": ["postgres"],
			"matchCurrentVersion": "13.4",
			"allowedVersions": "13.4"
		},
		{
			"matchManagers": ["npm", "rubygems"],
			"minimumReleaseAge": "7 days"
		},
		{
			"matchDepNames": ["ruby"],
			"matchDatasources": ["ruby-version"],
			"groupName": "ruby version",
			"groupSlug": "ruby"
		},
		{
			"matchDatasources": ["docker"],
			"matchPackageNames": ["ruby"],
			"enabled": false
		}
	]
}
