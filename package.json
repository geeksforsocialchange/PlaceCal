{
	"name": "placecal",
	"version": "3.0.0",
	"private": true,
	"dependencies": {
		"@hotwired/turbo-rails": "8.0.23",
		"@tailwindcss/cli": "4.3.2"
	},
	"devDependencies": {
		"daisyui": "5.6.10",
		"husky": "9.1.7",
		"leaflet": "1.9.4",
		"lint-staged": "17.0.8",
		"prettier": "3.9.4",
		"tom-select": "2.6.1"
	},
	"scripts": {
		"build": "yarn css-admin && yarn css-public",
		"build:all": "yarn build",
		"css-admin": "./node_modules/.bin/tailwindcss -i ./app/tailwind/admin_tailwind.css -o ./app/assets/builds/admin_tailwind.css --minify",
		"css-public": "./node_modules/.bin/tailwindcss -i ./app/tailwind/public_tailwind.css -o ./app/assets/builds/public_tailwind.css --minify",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky install"
	},
	"lint-staged": {
		"*.{css,html,js,json,md,scss,yml}": "prettier --write",
		"{*.{rb,jbuilder,rake,ru},.simplecov,Gemfile,Rakefile}": "bundle exec rubocop --force-exclusion --autocorrect"
	},
	"engines": {
		"node": "24.18.0"
	}
}
